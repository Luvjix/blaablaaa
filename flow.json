    "tosidebar": true,
    "console": false,
    "tostatus": false,
    "complete": "false",
    "targetType": "json",
    "statusVal": "",
    "statusType": "auto",
    "x": 810,
    "y": 220,
    "wires": []
  },
  {
    "id": "function_extract_F",
    "type": "function",
    "z": "tab_weather",
    "name": "Extract Wind Force",
    "func": "// extract wind force F\nlet msgOut = {\n    payload: msg.payload.F\n};\nreturn msgOut;",
    "outputs": 1,
    "noerr": 0,
    "x": 580,
    "y": 260,
    "wires": [["debug_F"]]
  },
